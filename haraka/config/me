# Haraka Configuration
# Server hostname
me=mail.protechplanner.com

# Listen on all interfaces
listen=0.0.0.0:25
listen=0.0.0.0:587
listen=0.0.0.0:465

# TLS configuration
tls_key=/etc/ssl/private/mail.protechplanner.com.key
tls_cert=/etc/ssl/certs/mail.protechplanner.com.crt

# Default domain
default_domain=protechplanner.com

# Max concurrent connections
max_connections=50

# Max recipients per connection
max_recipients=100

# Server timeouts
timeout=300

# Enable SMTP UTF8
smtp_utf8=true

# Max message size (10MB)
max_data_line_length=10485760

# Header settings
headers.add=Received: from mail.protechplanner.com
headers.add=X-Mailer: Haraka/protechplanner
