# Email Configuration (Haraka SMTP)
EMAIL_HOST=mail.protechplanner.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=info@protechplanner.com
EMAIL_PASS=your_password
EMAIL_DEFAULT_FROM=info@protechplanner.com

# Redis Configuration (for queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Haraka Server Configuration
HARAKA_SERVER=localhost
HARAKA_PORT=25
HARAKA_WEBHOOK_SECRET=your-webhook-secret

# Domain
DOMAIN=protechplanner.com

# DKIM Configuration
DKIM_DOMAIN=protechplanner.com
DKIM_SELECTOR=default
DKIM_PRIVATE_KEY=

# SES/SendGrid Fallback (optional)
SES_ENABLED=false
SES_REGION=us-east-1

# Cloudflare Workers (if deployed)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Environment
NODE_ENV=development
PORT=3000
